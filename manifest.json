{
  "manifest_version": 3,
  "name": "Download Router",
  "version": "1.0.4",
  "description": "Route downloads to specific folders based on priority rules (domain, file type, filename pattern).",
  "permissions": ["downloads", "storage", "contextMenus"],
  "browser_specific_settings": {
    "gecko": {
      "id": "download-router@local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
